# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_URL=https://your-app.railway.app

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ── Paystack ──────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key

# ── Signals channel ───────────────────────────────────────
# Create a Telegram channel, add the bot as admin, then get
# the channel ID using @userinfobot (e.g. -100123456789)
SIGNALS_CHANNEL_ID=@your_ngx_signals_channel

# ── Admin dashboard ───────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_password_here

# ── App config ────────────────────────────────────────────
APP_ENV=production
FREE_CREDITS_ON_SIGNUP=3
